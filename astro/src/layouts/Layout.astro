---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import LeftBar from "../components/LeftBar.astro";
import RightBar from "../components/RightBar.astro";

interface Props {
  title?: string;
}

const { title = "Tushar Agrawal" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Albert+Sans:wght@400;500;600;700;900&family=Cousine:wght@400;700&display=swap" rel="stylesheet" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<Header />
		<div class="page-container">
			<div class="left-bar-wrapper">
				<LeftBar />
			</div>
			<div class="footer-container">
				<div class="container">
					<slot />
				</div>
				<Footer />
			</div>
			<div class="right-bar-wrapper">
				<RightBar />
			</div>
		</div>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}

	.page-container {
		display: flex;
		flex-direction: row;
	}

	.footer-container {
		flex-grow: 1;
		display: flex;
		flex-direction: column;
	}

	.container {
		flex-grow: 1;
		padding: 0px;
		max-width: 1140px;
		margin: auto;
		margin-top: 70px;
	}

	.left-bar-wrapper,
	.right-bar-wrapper {
		display: none;
	}

	@media (min-width: 576px) {
		.left-bar-wrapper {
			display: flex;
		}
	}

	@media (min-width: 768px) {
		.container {
			padding: 20px;
		}
		.right-bar-wrapper {
			display: flex;
		}
	}
</style>
