---
import type { ProjectDocument } from '../types';

interface Props {
  project: ProjectDocument;
  reverse: boolean;
}

const { project, reverse } = Astro.props;
---

<div class:list={['container', { reverse }]}>
  <div class="image-container">
    <div class="image-background"></div>
    <img src={project.imageUrl} class="image" alt={project.title} />
  </div>
  <div class="content">
    <h4 class="project-title">{project.title}</h4>
    <div class="project-stack">
      {project.stack.map((item) => (
        <span>{item}</span>
      ))}
    </div>
    <div class="project-description" set:html={project.featuredBrief} />
  </div>
</div>

<style>
  .container {
    width: 100%;
    margin: 20px 0px;
    padding: 10px;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  .reverse {
    align-items: flex-start;
    flex-direction: column;
  }

  .image-container {
    max-width: 500px;
    position: relative;
    flex: 1;
    margin: 20px;
  }

  .image {
    width: 100%;
    height: 100%;
    transform: rotate(2deg);
  }

  .image-background {
    width: 100%;
    height: 100%;
    background-color: var(--secondary-low-opacity);
    transform: rotate(-6deg);
    position: absolute;
    top: 0px;
    left: 0px;
    z-index: 0;
  }

  .content {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    color: var(--text);
    flex: 1;
    padding: 10px;
  }

  .project-title {
    font-size: 32px;
    font-weight: 500;
  }

  .project-stack {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    width: 100%;
  }

  .project-stack span {
    margin-right: 10px;
    margin-top: 5px;
    font-family: var(--code-font);
    font-size: 14px;
    color: #c4c4c4;
  }

  .project-description {
    flex-grow: 1;
    margin-top: 10px;
  }

  .project-description :global(p) {
    margin: 5px 0px;
  }

  @media (min-width: 576px) {
    .project-title {
      font-size: 40px;
      font-weight: 500;
    }
  }

  @media (min-width: 992px) {
    .container {
      margin: 20px;
      flex-direction: row;
      align-items: flex-start;
    }
    .reverse {
      flex-direction: row-reverse;
    }
  }
</style>
