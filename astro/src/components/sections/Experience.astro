---
import type { ExperienceObject } from '../../types';

interface Props {
  experiences: ExperienceObject[];
}

const { experiences } = Astro.props;
---

<div class="container" id="experience">
  <h3 class="heading">Place I've Worked..</h3>
  <div class="content">
    <div class="tabs-container">
      {experiences.map((item, index) => (
        <div class="tab" data-experience-id={item._id} data-index={index}>
          <span>{item.company}</span>
          <div class="sideline" data-sideline={item._id}></div>
        </div>
      ))}
    </div>
    <div class="description-container">
      {experiences.map((item, index) => (
        <div class="description" data-description={item._id} data-index={index} style={index === experiences.length - 1 ? '' : 'display: none;'}>
          <h3 class="employment">
            {item.role}
            <a class="company-name" href={item.companyUrl} target="_blank" rel="noreferrer">
              {`@ ${item.company}`}
            </a>
          </h3>
          <p class="duration">{item.duration}</p>
          <div set:html={item.description} />
        </div>
      ))}
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('.tab');
    const descriptions = document.querySelectorAll('.description');
    const sidelines = document.querySelectorAll('.sideline');
    
    // Set initial active state
    const lastIndex = tabs.length - 1;
    tabs[lastIndex]?.classList.add('active');
    sidelines[lastIndex]?.classList.add('active');
    
    tabs.forEach((tab, index) => {
      tab.addEventListener('click', () => {
        // Hide all descriptions
        descriptions.forEach(desc => {
          (desc as HTMLElement).style.display = 'none';
        });
        
        // Remove active class from all tabs and sidelines
        tabs.forEach(t => t.classList.remove('active'));
        sidelines.forEach(s => s.classList.remove('active'));
        
        // Show selected description
        const description = descriptions[index] as HTMLElement;
        if (description) {
          description.style.display = 'block';
        }
        
        // Add active class to selected tab and sideline
        tab.classList.add('active');
        sidelines[index]?.classList.add('active');
      });
    });
  });
</script>

<style>
  .container {
    display: flex;
    justify-content: center;
    flex-direction: column;
    align-items: flex-start;
    overflow: hidden;
    min-height: 100vh;
  }

  .heading {
    color: var(--text);
    font-family: var(--primary-font);
    margin: 50px 10px 20px 10px;
    font-size: 30px;
  }

  .content {
    width: 100%;
    max-width: 700px;
    display: flex;
    flex-direction: column;
  }

  .tabs-container {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    width: 100vw;
    overflow: scroll;
    scrollbar-width: none;
  }

  .tabs-container::-webkit-scrollbar {
    display: none;
  }

  .tab {
    padding: 0px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    color: var(--text);
    width: 100%;
    cursor: pointer;
  }

  .tab:hover {
    background-color: var(--secondary-low-opacity);
  }

  .tab span {
    padding: 20px;
    white-space: nowrap;
  }

  .employment {
    font-size: 24px;
    color: var(--text);
  }

  .company-name {
    color: var(--secondary);
    margin-left: 10px;
  }

  .description-container {
    position: relative;
  }

  .description {
    color: var(--text);
    width: 100%;
    padding: 10px;
    padding-top: 0px;
  }

  .duration {
    font-family: var(--code-font);
    margin: 5px;
  }

  .description :global(ul) {
    padding: 10px;
  }

  .description :global(ul li) {
    margin: 10px;
  }

  .description :global(a) {
    text-decoration: none;
    color: var(--secondary);
    display: inline-block;
    position: relative;
  }

  .description :global(a::after) {
    content: '';
    position: absolute;
    width: 100%;
    transform: scaleX(0);
    height: 1px;
    bottom: 0px;
    left: 0px;
    background-color: var(--secondary);
    transform-origin: bottom right;
    transition: transform 0.25s ease-out;
  }

  .company-name::after {
    height: 2px;
    bottom: -2px;
  }

  .description :global(a:hover::after),
  .company-name:hover::after {
    transform: scaleX(1);
    transform-origin: bottom left;
  }

  .sideline {
    width: 100%;
    height: 2px;
    background-color: transparent;
    transition: background-color 0.3s ease;
  }

  .sideline.active {
    background-color: var(--secondary);
  }

  @media (min-width: 576px) {
    .content {
      flex-direction: row;
    }
    .tabs-container {
      width: 140px;
      flex-direction: column;
    }
    .tab {
      padding: 0px;
      display: flex;
      justify-content: space-between;
      flex-direction: row;
      color: var(--text);
      width: 100%;
    }
    .sideline {
      width: 5px;
      height: 100%;
      min-height: 55px;
    }
  }

  @media (min-width: 768px) {
    .tabs-container {
      width: 190px;
    }
    .heading {
      font-size: 48px;
    }
  }
</style>
